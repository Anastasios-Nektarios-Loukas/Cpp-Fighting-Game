## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Mono / Xamarin
*.userprefs
mono_crash.*

# Build results (κρατάμε εκτός bin/x64)
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/

[Dd]ebug/x64/
[Dd]ebugPublic/x64/
[Rr]elease/x64/
[Rr]eleases/x64/

[Dd]ebug/x86/
[Dd]ebugPublic/x86/
[Rr]elease/x86/
[Rr]eleases/x86/

# bin/
# **/[Bb]in/*
# bin/x64/
# bin/x86/

# Ignore intermediate build files
obj/
*.obj
*.idb
*.pdb
*.ilk
*.ipdb
*.iobj
*.pch
*.tlog

# Visual Studio cache
.vs/
ipch/
*.aps
*.ncb
*.opendb
*.sdf
*.VC.db

# Logs
*.log
[Ll]og/
[Ll]ogs/

# OS / temp
*.tmp
*.temp
*~

# Node
node_modules/

# Python
__pycache__/
*.pyc

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# -------------------------------
# INCLUDE BUILD FILES
# -------------------------------
!bin/
!bin/**
!x64/
!x64/**
!**/bin/
!**/bin/**
